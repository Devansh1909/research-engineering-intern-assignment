# NarrativeScope — Environment Variable Configuration
# Copy this file to `.env` and fill in your credentials.
# The app will read these automatically via python-dotenv (optional)
# or you can export them in your shell before running `streamlit run app.py`.

# Reddit API credentials
# Get yours at: https://www.reddit.com/prefs/apps  (create a "script" app)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=NarrativeScope/1.0 (research project)

# Google Gemini API key (optional — enables AI summaries)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
